{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    },
    "rootDir": ".",
    "isolatedModules": true
  },
  "include": [
    "app",
    "supabase.ts",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
